{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://siclient.local/schema/profile.schema.json",
  "title": "IMS Operator Profile",
  "type": "object",
  "required": ["profile_id", "home_domain", "pcscf", "transport", "security"],
  "additionalProperties": false,
  "properties": {
    "profile_id": {
      "type": "string",
      "minLength": 1
    },
    "home_domain": {
      "type": "string",
      "minLength": 1
    },
    "pcscf": {
      "type": "object",
      "required": ["mode"],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["static", "pco", "dhcp"]
        },
        "address": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "transport": {
      "type": "object",
      "required": ["preference"],
      "additionalProperties": false,
      "properties": {
        "preference": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["udp", "tcp", "tls"]
          }
        }
      }
    },
    "security": {
      "type": "object",
      "required": ["mechanism"],
      "additionalProperties": false,
      "properties": {
        "mechanism": {
          "type": "string",
          "enum": ["ipsec-3gpp", "tls"]
        }
      }
    },
    "codecs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "audio": {
          "type": "array",
          "items": { "type": "string" }
        },
        "video": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "preconditions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "fail_timeout_ms": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 60000
        }
      }
    },
    "timers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "registration_refresh_ratio": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 0.95
        },
        "keepalive_sec": {
          "type": "integer",
          "minimum": 10,
          "maximum": 300
        }
      }
    },
    "lab_sim": {
      "type": "object",
      "description": "Development-only SIM credentials and AKA test vectors",
      "required": ["impi", "impus"],
      "additionalProperties": false,
      "properties": {
        "impi": { "type": "string", "minLength": 1 },
        "impus": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "aka_vectors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["rand", "autn", "res", "ik", "ck"],
            "additionalProperties": false,
            "properties": {
              "rand": { "type": "string", "pattern": "^[0-9a-fA-F]{32}$" },
              "autn": { "type": "string", "pattern": "^[0-9a-fA-F]{32}$" },
              "res": { "type": "string", "pattern": "^[0-9a-fA-F]+$" },
              "ik": { "type": "string", "pattern": "^[0-9a-fA-F]{32}$" },
              "ck": { "type": "string", "pattern": "^[0-9a-fA-F]{32}$" },
              "auts": { "type": "string", "pattern": "^[0-9a-fA-F]{28}$" }
            }
          }
        }
      }
    }
  }
}
